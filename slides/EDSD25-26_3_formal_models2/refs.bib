	file = {Full Text:C\:\\Users\\alburezgutierrez\\Zotero\\storage\\BMLSFUYJ\\Pilkauskas and Cross - 2018 - Beyond the Nuclear Family Trends in Children Livi.pdf:application/pdf},
}

